# Copy this file to .env.local and fill in values for your environment.
# In development, the Vite proxy (/api -> http://localhost:8000) handles routing
# automatically — no env vars needed.

# --- Vercel (multi-service, vercel.json) ---
# VITE_API_BASE=/_/backend/api

# --- Separate backend deployment (Railway / Render / Fly.io) ---
# VITE_API_BASE=https://your-backend.railway.app/api
