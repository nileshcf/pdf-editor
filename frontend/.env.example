# Copy this file to .env.local and fill in values for your environment.
# In development, the Vite proxy (/api -> http://localhost:8000) handles routing
# automatically — no env vars needed.

# --- Production: frontend on Vercel, backend on Render ---
# Point this at your Render backend's public URL + "/api" (no trailing slash).
# Set it in the Vercel dashboard (Project Settings → Environment Variables).
# VITE_API_BASE=https://aeropdf-backend.onrender.com/api
